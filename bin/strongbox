#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/storage.sh"
source "$LIB_DIR/crypto.sh"
source "$LIB_DIR/auth.sh"
source "$LIB_DIR/lease.sh"
source "$LIB_DIR/dynamic.sh"
source "$LIB_DIR/consensus.sh"
source "$LIB_DIR/audit.sh"
source "$LIB_DIR/http.sh"

NODE_ID="${NODE_ID:-node1}"
NODE_PORT="${NODE_PORT:-8201}"

IS_SEALED=true
UNSEAL_SHARES=()
UNSEAL_THRESHOLD="${UNSEAL_THRESHOLD:-3}"
UNSEAL_TOTAL="${UNSEAL_TOTAL:-5}"
INITIALIZED=false
INIT_FILE="/data/initialized"

storage_init
auth_init
lease_init
audit_init
consensus_init

echo "StrongBox $NODE_ID starting port=$NODE_PORT SEALED"

[[ -f "$INIT_FILE" ]] && INITIALIZED=true && echo "Already initialized"

consensus_election_watcher &
lease_reaper &

handle() {
http_parse
echo "DEBUGMARKER_M=[$HTTP_METHOD]_P=[$HTTP_PATH]_Q=[$HTTP_QUERY]" >&2

local M="$HTTP_METHOD" P="$HTTP_PATH" B="$HTTP_BODY" T="$HTTP_TOKEN"

# Sealed gate - only health, unseal, init pass through
if $IS_SEALED; then
if [[ "$P" != "/v1/sys/health" ]] && \
[[ "$P" != "/v1/sys/unseal" ]] && \
[[ "$P" != "/v1/sys/init" ]]; then
http_respond 503 '{"error":"vault is sealed"}'
return
fi
fi

# GET /v1/sys/health
if [[ "$M" == "GET" && "$P" == "/v1/sys/health" ]]; then
local leader sealed
leader=$(consensus_get_leader)
$IS_SEALED && sealed="true" || sealed="false"
http_respond 200 "{\"sealed\":$sealed,\"leader\":\"$leader\",\"term\":$CURRENT_TERM,\"node_id\":\"$NODE_ID\"}"
return
fi

# POST /v1/sys/init
if [[ "$M" == "POST" && "$P" == "/v1/sys/init" ]]; then
if $INITIALIZED; then
http_respond 400 '{"error":"already initialized"}'
return
fi
local master_key shares_json shares_output root_result root_token
master_key=$(openssl rand -hex 32)
shares_json=$(python3 "$LIB_DIR/shamir.py" split "$master_key" "$UNSEAL_TOTAL" "$UNSEAL_THRESHOLD")
shares_output=$(echo "$shares_json" | python3 -c "
import sys,json
shares=json.load(sys.stdin)
print(json.dumps([str(s['x'])+':'+s['y'] for s in shares]))
")
auth_create_policy "root" '{"rules":[{"path":"*","capabilities":["read","write","delete"]}]}'
root_result=$(auth_create_token "root" 876000)
root_token=$(echo "$root_result" | python3 -c "import sys,json; print(json.load(sys.stdin)['token'])")
master_key=""
touch "$INIT_FILE"
INITIALIZED=true
audit_append "init" "/" "system"
http_respond 200 "{\"shares\":$shares_output,\"root_token\":\"$root_token\"}"
return
fi

# POST /v1/sys/unseal
if [[ "$M" == "POST" && "$P" == "/v1/sys/unseal" ]]; then
local share
share=$(http_json "$B" "share")
UNSEAL_SHARES+=("$share")
local progress=${#UNSEAL_SHARES[@]}

if [[ $progress -ge $UNSEAL_THRESHOLD ]]; then
local shares_arg
shares_arg=$(python3 -c "
import json
shares='${UNSEAL_SHARES[*]}'.split()
result=[]
for s in shares[:$UNSEAL_THRESHOLD]:
x,y=s.split(':',1)
result.append({'x':int(x),'y':y})
print(json.dumps(result))
")
local master_key
master_key=$(python3 "$LIB_DIR/shamir.py" reconstruct "$shares_arg" 32)
crypto_set_kek "$master_key"
master_key=""
UNSEAL_SHARES=()
IS_SEALED=false
audit_append "unseal" "/" "operator"
http_respond 200 "{\"sealed\":false,\"progress\":\"${UNSEAL_THRESHOLD}/${UNSEAL_THRESHOLD}\"}"
else
http_respond 200 "{\"sealed\":true,\"progress\":\"${progress}/${UNSEAL_THRESHOLD}\"}"
fi
return
fi

# POST /v1/sys/seal
if [[ "$M" == "POST" && "$P" == "/v1/sys/seal" ]]; then
local meta
meta=$(auth_validate_token "$T" 2>/dev/null) || {
http_respond 401 '{"error":"unauthorized"}'
return
}
crypto_clear_kek
IS_SEALED=true
audit_append "seal" "/" "$T"
http_respond 204 ""
return
fi

# Auth middleware for all routes below
local meta token_id
meta=$(auth_validate_token "$T" 2>/dev/null) || {
http_respond 401 '{"error":"unauthorized"}'
return
}
token_id=$(echo "$meta" | python3 -c "import sys,json; print(json.load(sys.stdin)['token_id'])")

# POST /v1/auth/login
if [[ "$M" == "POST" && "$P" == "/v1/auth/login" ]]; then
local user pass result
user=$(http_json "$B" "username")
pass=$(http_json "$B" "password")
result=$(auth_login "$user" "$pass") && {
audit_append "login" "/" "$user"
http_respond 200 "$result"
} || http_respond 401 '{"error":"invalid credentials"}'
return
fi

# POST /v1/auth/revoke
if [[ "$M" == "POST" && "$P" == "/v1/auth/revoke" ]]; then
local rt
rt=$(http_json "$B" "token")
auth_revoke_token "$rt" && {
audit_append "revoke" "/" "$token_id"
http_respond 204 ""
} || http_respond 404 '{"error":"token not found"}'
return
fi

# GET /v1/auth/self
if [[ "$M" == "GET" && "$P" == "/v1/auth/self" ]]; then
http_respond 200 "$meta"
return
fi

# PUT /v1/policies/{name}
if [[ "$M" == "PUT" && "$P" =~ ^/v1/policies/(.+)$ ]]; then
local pname="${BASH_REMATCH[1]}"
auth_check_policy "$token_id" "write" "policies/$pname" || {
http_respond 403 '{"error":"forbidden"}'
return
}
auth_create_policy "$pname" "$B"
audit_append "policy_write" "policies/$pname" "$token_id"
http_respond 201 '{"status":"created"}'
return
fi

# GET /v1/policies/{name}
if [[ "$M" == "GET" && "$P" =~ ^/v1/policies/(.+)$ ]]; then
local pname="${BASH_REMATCH[1]}"
local pd
pd=$(auth_get_policy "$pname") && http_respond 200 "$pd" || \
http_respond 404 '{"error":"not found"}'
return
fi

# PUT /v1/secrets/{path}
if [[ "$M" == "PUT" && "$P" =~ ^/v1/secrets/(.+)$ ]]; then
local spath="${BASH_REMATCH[1]}"
auth_check_policy "$token_id" "write" "secret/$spath" || {
http_respond 403 '{"error":"forbidden"}'
return
}
consensus_is_leader || {
local leader
leader=$(consensus_get_leader)
http_respond 503 "{\"error\":\"not leader\",\"leader\":\"$leader\"}"
return
}
local enc version
enc=$(crypto_encrypt_secret "$B") || {
http_respond 503 '{"error":"encryption failed - vault may be sealed"}'
return
}
version=$(storage_put_version "secret/$spath" "$enc")
audit_append "secret_write" "secret/$spath" "$token_id"
http_respond 201 "{\"version\":$version}"
return
fi

# GET /v1/secrets/{path}
if [[ "$M" == "GET" && "$P" =~ ^/v1/secrets/(.+)$ ]]; then
local spath="${BASH_REMATCH[1]}"
local ver=""
[[ "$HTTP_QUERY" =~ version=([0-9]+) ]] && ver="${BASH_REMATCH[1]}"
auth_check_policy "$token_id" "read" "secret/$spath" || {
http_respond 403 '{"error":"forbidden"}'
return
}
local enc
enc=$(storage_get_version "secret/$spath" "$ver") || {
http_respond 404 '{"error":"not found"}'
return
}
local ct n wd dn plain
ct=$(echo "$enc" | python3 -c "import sys,json; print(json.load(sys.stdin)['ciphertext'])")
n=$(echo "$enc" | python3 -c "import sys,json; print(json.load(sys.stdin)['nonce'])")
wd=$(echo "$enc" | python3 -c "import sys,json; print(json.load(sys.stdin)['wrapped_dek'])")
dn=$(echo "$enc" | python3 -c "import sys,json; print(json.load(sys.stdin)['dek_nonce'])")
plain=$(crypto_decrypt_secret "$ct" "$n" "$wd" "$dn") || {
http_respond 503 '{"error":"decryption failed"}'
return
}
local latest lease
latest=$(storage_latest_version "secret/$spath")
lease=$(lease_create "secret/$spath" "$token_id")
audit_append "secret_read" "secret/$spath" "$token_id"
http_respond 200 "{\"data\":$plain,\"version\":$latest,\"lease\":$lease}"
return
fi

# DELETE /v1/secrets/{path}
if [[ "$M" == "DELETE" && "$P" =~ ^/v1/secrets/(.+)$ ]]; then
local spath="${BASH_REMATCH[1]}"
auth_check_policy "$token_id" "delete" "secret/$spath" || {
http_respond 403 '{"error":"forbidden"}'
return
}
storage_delete "secret/$spath"
audit_append "secret_delete" "secret/$spath" "$token_id"
http_respond 204 ""
return
fi

# GET /v1/dynamic-postgres/{role}
if [[ "$M" == "GET" && "$P" =~ ^/v1/dynamic-postgres/(.+)$ ]]; then
local rprefix="${BASH_REMATCH[1]}"
auth_check_policy "$token_id" "read" "dynamic-postgres/$rprefix" || {
http_respond 403 '{"error":"forbidden"}'
return
}
local creds
creds=$(dynamic_mint_postgres_role "$rprefix") || {
http_respond 503 '{"error":"database unreachable"}'
return
}
local lease lid uname pw
lease=$(lease_create "dynamic-postgres/$rprefix" "$token_id" 3600)
lid=$(echo "$lease" | python3 -c "import sys,json; print(json.load(sys.stdin)['lease_id'])")
uname=$(echo "$creds" | python3 -c "import sys,json; print(json.load(sys.stdin)['username'])")
pw=$(echo "$creds" | python3 -c "import sys,json; print(json.load(sys.stdin)['password'])")
# Store role name in lease for reaper cleanup
python3 -c "
import json
lf='$LEASE_DIR/${lid}.json'
with open(lf) as f: d=json.load(f)
d['pg_role']='$uname'
with open(lf,'w') as f: json.dump(d,f)
"
audit_append "dynamic_read" "dynamic-postgres/$rprefix" "$token_id"
http_respond 200 "{\"username\":\"$uname\",\"password\":\"$pw\",\"lease\":$lease}"
return
fi

# POST /v1/leases/{id}/renew
if [[ "$M" == "POST" && "$P" =~ ^/v1/leases/([^/]+)/renew$ ]]; then
local lid="${BASH_REMATCH[1]}"
local result
result=$(lease_renew "$lid") && http_respond 200 "{\"new_expires_at\":\"$result\"}" || \
http_respond 400 '{"error":"cannot renew"}'
return
fi

# POST /v1/leases/{id}/revoke
if [[ "$M" == "POST" && "$P" =~ ^/v1/leases/([^/]+)/revoke$ ]]; then
local lid="${BASH_REMATCH[1]}"
lease_revoke "$lid"
http_respond 204 ""
return
fi

# GET /v1/audit
if [[ "$M" == "GET" && "$P" == "/v1/audit" ]]; then
local qt=""
[[ "$HTTP_QUERY" =~ token=([^&]+) ]] && qt="${BASH_REMATCH[1]}"
http_respond 200 "$(audit_query "$qt")"
return
fi

# Internal vote
if [[ "$M" == "POST" && "$P" == "/internal/vote" ]]; then
local term cid
term=$(http_json "$B" "term")
cid=$(http_json "$B" "candidate_id")
http_respond 200 "$(consensus_handle_vote "$term" "$cid")"
return
fi

# Internal heartbeat
if [[ "$M" == "POST" && "$P" == "/internal/heartbeat" ]]; then
local term lid
term=$(http_json "$B" "term")
lid=$(http_json "$B" "leader_id")
http_respond 200 "$(consensus_handle_heartbeat "$term" "$lid")"
return
fi

http_respond 404 '{"error":"not found"}'
}

echo "Listening on port $NODE_PORT"
REQ_FIFO="/tmp/sb_req_$NODE_PORT"
RESP_FIFO="/tmp/sb_resp_$NODE_PORT"
rm -f "$REQ_FIFO" "$RESP_FIFO"
mkfifo "$REQ_FIFO" "$RESP_FIFO"

while true; do
  socat TCP-LISTEN:"$NODE_PORT",reuseaddr \
    SYSTEM:"stdbuf -o0 cat > $REQ_FIFO & stdbuf -o0 cat $RESP_FIFO"
done &
while true; do
  handle < "$REQ_FIFO" > "$RESP_FIFO"
done
